Algoritmo "Problema multiplos"

Var

   a, b : inteiro

Inicio

      escreval("Digite dois numeros inteiros: ")
      leia(a)
      leia(b)
      
      se (a % b = 0) ou (b % a = 0) ent„o
         escreval("Sao multiplos")
      sen„o
           escreval("N„o sao multiplos")
      fimse
      

Fimalgoritmo