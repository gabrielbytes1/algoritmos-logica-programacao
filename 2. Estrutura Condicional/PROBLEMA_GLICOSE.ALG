Algoritmo "Problema glicose"

Var

   glicose : real

Inicio

      escreva("Digite a medida da glicose: ")
      leia(glicose)
      
      se glicose <= 100 ent„o
         escreval("Classificacao: normal")
      sen„o
           se glicose <= 140 ent„o
              escreval("Classificacao: elevado")
           sen„o
                escreval("Classificacao: diabetes")
           fimse
      fimse


Fimalgoritmo